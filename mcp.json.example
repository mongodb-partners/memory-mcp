{
  "_comment": "Copy one of the examples below into your mcp.json",

  "_1_http": "Connect to a running memory-mcp HTTP server (no auth)",
  "servers": {
    "memory-mcp": {
      "url": "http://localhost:8000/mcp",
      "type": "http"
    }
  },

  "_2_http_with_auth": "HTTP with API key or JWT authentication",
  "servers_http_auth": {
    "memory-mcp": {
      "url": "http://localhost:8000/mcp",
      "headers": {
        "Authorization": "Bearer your-api-key-here"
      },
      "type": "http"
    }
  },

  "_3_stdio": "Launch memory-mcp as a stdio subprocess (no auth)",
  "servers_stdio": {
    "memory-mcp": {
      "command": "memory-mcp",
      "env": {
        "TRANSPORT": "stdio",
        "MONGODB_CONNECTION_STRING": "mongodb+srv://user:pass@cluster.mongodb.net/memory_mcp"
      }
    }
  },

  "_4_stdio_with_auth": "Stdio with auth enabled (server-side API key validation)",
  "servers_stdio_auth": {
    "memory-mcp": {
      "command": "memory-mcp",
      "env": {
        "TRANSPORT": "stdio",
        "MONGODB_CONNECTION_STRING": "mongodb+srv://user:pass@cluster.mongodb.net/memory_mcp",
        "AUTH_ENABLED": "true",
        "AUTH_SECRET": "your-hs256-secret-key-min-32-chars",
        "MEMORY_MCP_API_KEYS": "your-api-key-here=user1"
      }
    }
  }
}
