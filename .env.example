# MongoDB Atlas connection string (required)
MONGODB_CONNECTION_STRING=mongodb+srv://user:password@cluster.mongodb.net/memory_mcp

# MongoDB database name (default: memory_mcp)
# MONGODB_DATABASE_NAME=memory_mcp

# AWS Bedrock credentials (required for default embedding/LLM providers)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# Embedding provider: "bedrock" (default) or "voyage"
# EMBEDDING_PROVIDER=bedrock

# LLM provider: "bedrock" (default)
# LLM_PROVIDER=bedrock

# Voyage AI (required if EMBEDDING_PROVIDER=voyage)
# VOYAGE_API_KEY=your-voyage-api-key

# Tavily web search (optional, enables search_web tool)
# TAVILY_API_KEY=your-tavily-api-key

# Auth (optional, disabled by default)
# AUTH_ENABLED=true
# AUTH_SECRET=your-jwt-signing-secret
# AUTH_TOKEN_EXPIRY_SECONDS=86400
# MEMORY_MCP_API_KEYS=key1=user1@company.com,key2=user2@company.com
